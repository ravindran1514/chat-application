rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isChatParticipant() {
      return signedIn()
        && request.auth.uid in resource.data.participantIds;
    }

    function isParticipant(chatId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant();
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isChatParticipant()
        || (signedIn()
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantIds', 'participantNames', 'updatedAt']));
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isParticipant(chatId)
          && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
